FACE_SERVICE_PORT=8001

IRIS_SERVICE_HOST=127.0.0.1
IRIS_SERVICE_PORT=8002

LIVENESS_SERVICE_HOST=127.0.0.1
LIVENESS_SERVICE_PORT=8003

# Database
